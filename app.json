{
  "expo": {
    "name": "SavorSelf",
    "slug": "savorself",
    "scheme": "savorself",
    "version": "1.0.0",
    "icon": "./logo.png",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./background.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF7F2"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.savorself.app",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./logo.png",
        "backgroundColor": "#FAF7F2"
      },
      "package": "com.savorself.app",
      "versionCode": 1
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-notifications",
      "expo-camera"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
